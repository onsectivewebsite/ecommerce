# --- API service ---
NODE_ENV=development
API_PORT=4000
PUBLIC_API_URL=http://localhost:4000

# Postgres
DATABASE_URL=postgresql://onsective:onsective@localhost:5432/onsective?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# MinIO (S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=onsective
MINIO_SECRET_KEY=onsective-secret
MINIO_BUCKET=onsective-media

# Payments (provider-agnostic abstraction; Mock works without keys)
DEFAULT_PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URLs (CORS allow-list)
BUYER_WEB_URL=http://localhost:3000
SELLER_WEB_URL=http://localhost:3001
ADMIN_WEB_URL=http://localhost:3002
SHIPPING_WEB_URL=http://localhost:3003

# Platform
PLATFORM_DEFAULT_CURRENCY=USD
PLATFORM_DEFAULT_LOCALE=en
PLATFORM_DEFAULT_COMMISSION_BPS=1500
PLATFORM_FLAT_SHIPPING_MINOR=499
PLATFORM_FLAT_TAX_BPS=800

# Carriers (each optional — when absent the adapter returns mock pricing)
FEDEX_API_KEY=
FEDEX_API_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_BASE_URL=https://apis-sandbox.fedex.com

UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_BASE_URL=https://wwwcie.ups.com

DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_BASE_URL=https://express.api.dhl.com/mydhlapi/test

CANADAPOST_USERNAME=
CANADAPOST_PASSWORD=
CANADAPOST_CUSTOMER_NUMBER=
CANADAPOST_BASE_URL=https://ct.soa-gw.canadapost.ca
