// ---------------------------------------------------------------------------
// Phase 27 — In-app notification feed
// ---------------------------------------------------------------------------

enum NotificationKind {
  PLUS_RENEWED
  PLUS_PAYMENT_FAILED
  PLUS_EXPIRING_SOON
  PLUS_EXPIRED
  REFERRAL_REDEEMED
  ORDER_PAID
  ORDER_SHIPPED
  ORDER_DELIVERED
  MESSAGE_NEW
  REVIEW_POSTED
  QUESTION_ANSWERED
  SAVED_SEARCH_MATCH
  SECURITY_SIGN_IN
  GENERIC
}

model Notification {
  id            String           @id
  userId        String
  kind          NotificationKind
  title         String
  body          String
  /// In-app navigation target (e.g., "/orders/abc"). Frontend decides
  /// whether to in-app-navigate or full-reload.
  deepLinkPath  String?
  /// Snapshot of the contextual data (e.g., { orderId, totalMinor }). Kept
  /// small — large fields belong in the linked entity.
  payload       Json?
  readAt        DateTime?
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ---------------------------------------------------------------------------
// Phase 30 — Rate limiting + abuse prevention
// ---------------------------------------------------------------------------

enum AbuseEventKind {
  RATE_LIMIT_EXCEEDED
  REPEAT_VIOLATION
  MANUAL_BLOCK
}

enum RateLimitBlockSource {
  MANUAL
  AUTO
}

model AbuseEvent {
  id          String         @id
  ruleId      String
  /// Composite identifier the limiter blocked on, e.g.
  /// "auth.login:ip:203.0.113.42" or "orders.checkout:user:u_abc".
  key         String
  kind        AbuseEventKind
  ip          String?
  userAgent   String?
  userId      String?
  requestPath String?
  createdAt   DateTime       @default(now())

  @@index([ruleId, createdAt])
  @@index([key, createdAt])
  @@index([userId, createdAt])
}

model RateLimitBlock {
  id              String               @id
  /// Same composite shape as AbuseEvent.key. Unique so an AUTO block can
  /// be upserted idempotently when escalation thresholds are crossed.
  key             String               @unique
  ruleId          String
  reason          String
  source          RateLimitBlockSource
  /// null = indefinite (admin must clear).
  blockedUntil    DateTime?
  blockedByUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([blockedUntil])
  @@index([ruleId, createdAt])
}

// ───────────────────────── Phase 31: Two-Factor Auth ─────────────────────────

enum TwoFactorEnrollmentStatus {
  PENDING
  ACTIVE
}

enum TwoFactorChallengeKind {
  LOGIN
  DISABLE
  WEBAUTHN_REGISTER
  WEBAUTHN_LOGIN
}

model TotpEnrollment {
  id             String                    @id
  userId         String                    @unique
  /// AES-256-GCM ciphertext of the raw 20-byte TOTP secret, base64.
  secretCipher   String
  /// 12-byte GCM IV, base64.
  secretIv       String
  /// 16-byte GCM auth tag, base64.
  secretTag      String
  status         TwoFactorEnrollmentStatus @default(PENDING)
  /// Highest TOTP step counter we've accepted. Used for replay protection:
  /// reject any submitted code whose step is <= this value.
  lastUsedStep   BigInt                    @default(0)
  activatedAt    DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecoveryCode {
  id        String    @id
  userId    String
  /// argon2(code). Cleartext is shown exactly once at issue-time.
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TwoFactorChallenge {
  id         String                  @id
  userId     String
  kind       TwoFactorChallengeKind
  /// sha256 of the opaque token handed to the client.
  tokenHash  String                  @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime                @default(now())

  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@index([expiresAt])
}

// ───────────────────────── Phase 32: Consent & Marketing Preferences ─────────────────────────

enum ConsentCategory {
  ESSENTIAL
  FUNCTIONAL
  ANALYTICS
  MARKETING
}

enum ConsentSource {
  BANNER
  PREFERENCES_PAGE
  UNSUBSCRIBE_LINK
  ADMIN_OVERRIDE
  IMPORT
}

enum ConsentRegion {
  EU
  UK
  CA
  REST
}

model ConsentRecord {
  id              String        @id
  /// Exactly one of userId / anonId is set. Logged-in users get a userId-keyed
  /// record; anonymous visitors get an anonId-keyed one. On login we copy the
  /// anon record over (or keep the user record if both exist).
  userId          String?       @unique
  anonId          String?       @unique
  region          ConsentRegion
  /// Bumped when the cookie policy / privacy policy text materially changes;
  /// stale records can be detected and re-prompted by the banner.
  policyVersion   String
  essential       Boolean       @default(true)
  functional      Boolean       @default(false)
  analytics       Boolean       @default(false)
  marketing       Boolean       @default(false)
  marketingEmail  Boolean       @default(false)
  marketingSms    Boolean       @default(false)
  marketingPush   Boolean       @default(false)
  source          ConsentSource
  ipHash          String?
  userAgent       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  events          ConsentEvent[]
}

model ConsentEvent {
  id            String        @id
  consentId     String
  userId        String?
  anonId        String?
  source        ConsentSource
  region        ConsentRegion
  policyVersion String
  before        Json
  after         Json
  ipHash        String?
  userAgent     String?
  createdAt     DateTime      @default(now())
  consent       ConsentRecord @relation(fields: [consentId], references: [id], onDelete: Cascade)

  @@index([consentId, createdAt])
  @@index([userId, createdAt])
}

model UnsubscribeToken {
  id          String    @id
  userId      String
  /// sha256 of the opaque token handed to the user via the email link.
  tokenHash   String    @unique
  /// Which preference column to flip false on consumption. Today the only
  /// value emitted by the email module is "marketingEmail", but the column
  /// is extensible so we can ship "marketingSms" / "marketingPush" later.
  category    String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ───────────────────────── Phase 33: WebAuthn / Passkeys ─────────────────────────

enum WebAuthnCredentialTransport {
  USB
  NFC
  BLE
  INTERNAL
  HYBRID
}

model WebAuthnCredential {
  id            String                          @id
  userId        String
  /// base64url credentialId (the authenticator-generated handle).
  credentialId  String                          @unique
  /// COSE-format public key (CBOR-encoded), stored as base64url. We re-parse
  /// on every assertion verify — small, deterministic, and avoids JWK conversion drift.
  publicKey     String
  /// COSE algorithm identifier: -7 ES256, -257 RS256, -8 EdDSA.
  algorithm     Int
  /// Monotonic counter from the authenticator. We reject any assertion that
  /// doesn't strictly increase this — except authenticators that always emit 0
  /// (Apple platform passkeys), which we detect via the special "both zero" rule.
  signCount     Int                             @default(0)
  /// User-friendly label shown on /account/security.
  label         String
  transports    WebAuthnCredentialTransport[]
  /// rk=true at registration. Required for username-less / discoverable login.
  discoverable  Boolean                         @default(false)
  /// User-verification was performed at registration (Touch ID, PIN, etc).
  userVerified  Boolean                         @default(false)
  /// 16-byte AAGUID (hex) of the authenticator. Useful for diagnostics
  /// and future strong-attestation policies.
  aaguid        String?
  lastUsedAt    DateTime?
  createdAt     DateTime                        @default(now())
  updatedAt     DateTime                        @updatedAt
  user          User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ───────────────────────── Phase 34: Account Recovery ─────────────────────────

enum RecoveryRequestStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

model PasswordResetToken {
  id         String    @id
  userId     String
  /// sha256 of the opaque token in the reset email link.
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AccountRecoveryRequest {
  id                String                @id
  userId            String
  status            RecoveryRequestStatus @default(PENDING)
  /// sha256 of the "yes, continue recovery" link token.
  confirmTokenHash  String                @unique
  /// sha256 of the "this wasn't me / cancel" link token. Works at any stage.
  cancelTokenHash   String                @unique
  /// sha256 of the token used to actually finish recovery once eligible.
  completeTokenHash String                @unique
  requestedAt       DateTime              @default(now())
  confirmedAt       DateTime?
  /// confirmedAt + 72h. 2FA cannot be removed before this instant.
  eligibleAt        DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  /// Number of reminder emails sent during the CONFIRMED waiting window.
  remindersSent     Int                   @default(0)
  ip                String?
  userAgent         String?
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, eligibleAt])
}

// ───────────────────────── Phase 35: Gift Cards ─────────────────────────

enum GiftCardStatus {
  PENDING_PAYMENT
  ACTIVE
  REDEEMED
  VOID
  EXPIRED
}

model GiftCard {
  id                 String         @id
  /// Human-friendly code, e.g. ONS-7F3K-9QMP-24XY. Stored uppercase; redeem
  /// matches case-insensitively after normalization.
  code               String         @unique
  status             GiftCardStatus @default(PENDING_PAYMENT)
  currency           String         @default("USD")
  initialAmountMinor Int
  /// Remaining redeemable balance — equals initial until redeemed, then 0.
  balanceMinor       Int
  /// null for admin-issued promotional cards.
  purchaserUserId    String?
  recipientEmail     String
  recipientName      String?
  senderName         String?
  message            String?
  /// Scheduled send. null = deliver as soon as payment captures.
  deliverAt          DateTime?
  deliveredAt        DateTime?
  redeemedByUserId   String?
  redeemedAt         DateTime?
  /// Stripe PaymentIntent id for buyer purchases.
  paymentRef         String?
  /// null = no expiry (the compliant default for paid cards).
  expiresAt          DateTime?
  issuedByAdminId    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  purchaser User? @relation("GiftCardPurchaser", fields: [purchaserUserId], references: [id], onDelete: SetNull)
  redeemer  User? @relation("GiftCardRedeemer", fields: [redeemedByUserId], references: [id], onDelete: SetNull)

  @@index([status, deliverAt])
  @@index([purchaserUserId])
  @@index([recipientEmail])
}


