// ============================================================================
// Phase 20 — Sustainability & Trade Reporting
// ============================================================================

enum SustainabilitySubjectKind {
  REFURB_PURCHASE
  OPENBOX_PURCHASE
  TRADEIN_PAYOUT
  REPAIR_COMPLETED
}

 /// Per-category baseline. Optional brandId override beats the
 /// categorySlug-only row at lookup time. Editable by admin; new events use
 /// the new values, but past SustainabilityImpact rows are snapshotted and
 /// never recompute.
model SustainabilityFactor {
  id                   String   @id
  categorySlug         String
  brandId              String?
  kgCo2PerRefurb       Float    @default(0)
  kgMaterialPerRefurb  Float    @default(0)
  lifeExtensionYears   Float    @default(0)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([categorySlug, brandId])
  @@index([categorySlug])
}

 /// One per circular event. subjectId is a loose FK (no Prisma relation)
 /// because the source table varies by subjectKind — same pattern as
 /// AiInferenceRun.inputRefId.
model SustainabilityImpact {
  id                  String                    @id
  subjectKind         SustainabilitySubjectKind
  subjectId           String
  buyerUserId         String?
  sellerId            String?
  brandId             String?
  categorySlug        String
  kgCo2Saved          Float                     @default(0)
  kgMaterialDiverted  Float                     @default(0)
  lifeExtensionYears  Float                     @default(0)
  reason              String?
  createdAt           DateTime                  @default(now())

  @@unique([subjectKind, subjectId])
  @@index([buyerUserId, createdAt])
  @@index([brandId, createdAt])
  @@index([categorySlug, createdAt])
}

// ============================================================================
// Phase 21 — Multi-warehouse Smart Routing & SLA
// ============================================================================

enum SlaBreachKind {
  SHIP
  DELIVER
}

 /// Per-warehouse SLA per destination. region is nullable for the
 /// country-default profile. Lookup priority is
 /// (warehouseId, country, region) → (warehouseId, country, null) → null.
model WarehouseSlaProfile {
  id            String   @id
  warehouseId   String
  country       String
  region        String?
  shipDays      Int
  deliveryDays  Int
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, country, region])
  @@index([country, region])
}

 /// Breach event log. The scheduler writes one row when an OrderItem's
 /// promisedShipBy/promisedDeliverBy passes without the corresponding
 /// completion. Uniqueness on (orderItemId, kind) prevents double-write
 /// when the scheduler re-runs.
model SlaBreach {
  id            String        @id
  orderItemId   String
  kind          SlaBreachKind
  promisedAt    DateTime
  detectedAt    DateTime      @default(now())
  breachHours   Float
  sellerId      String?
  createdAt     DateTime      @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([orderItemId, kind])
  @@index([sellerId, createdAt])
  @@index([kind, createdAt])
}

// ============================================================================
// Phase 22 — Loyalty & Membership
// ============================================================================

enum MembershipPlan {
  PLUS_MONTHLY
  PLUS_ANNUAL
}

enum MembershipStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED
}

enum PointsTransactionKind {
  EARN_PURCHASE
  EARN_REFURB
  EARN_TRADEIN
  EARN_REPAIR
  EARN_BONUS
  REDEEM_WALLET
  ADJUST
}

model PlusMembership {
  id              String           @id
  userId          String           @unique
  plan            MembershipPlan
  status          MembershipStatus @default(ACTIVE)
  startedAt       DateTime         @default(now())
  expiresAt       DateTime
  renewedAt       DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  // Snapshot of price paid at term start (for the buyer's history view).
  pricePaidMinor  Int
  currency        String
  // Loose reference to the payment that funded this term. We don't FK
  // because Payment rows in the existing schema are owned by Order.
  paymentRef      String?
  // Phase 23: Stripe Subscription mirror. providerSubscriptionId is null
  // for legacy Phase-22 rows started before recurring billing landed.
  providerSubscriptionId String?  @unique
  autoRenew              Boolean  @default(true)
  currentPeriodEnd       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingEvents MembershipBillingEvent[]

  @@index([status])
  @@index([expiresAt])
  @@index([providerSubscriptionId])
}

model PointsAccount {
  id        String   @id
  userId    String   @unique
  balance   Int      @default(0)
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions PointsTransaction[]
}

model PointsTransaction {
  id            String                @id
  accountId     String
  amount        Int
  kind          PointsTransactionKind
  balanceAfter  Int
  reason        String?
  /// Idempotency key — duplicate writes for the same event are rejected
  /// by the unique constraint. Examples: "purchase:<orderId>",
  /// "tradein:<orderId>", "repair:<ticketId>", "redeem:<txId>".
  referenceKey  String?               @unique
  orderId       String?
  createdAt     DateTime              @default(now())

  account PointsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([kind, createdAt])
}

// ---------------------------------------------------------------------------
// Phase 23 — Recurring Billing & Saved Payment Methods
// ---------------------------------------------------------------------------

enum PaymentMethodStatus {
  ACTIVE
  DETACHED
}

enum MembershipBillingEventKind {
  INVOICE_PAID
  INVOICE_FAILED
  SUB_UPDATED
  SUB_DELETED
  /// Phase 24: idempotent marker that the buyer has been emailed an
  /// "expiring soon" reminder for the current term. providerEventId is
  /// synthesized as `reminder:<membershipId>:<currentPeriodEnd-iso>`.
  NOTICE_SENT
}

model PaymentMethod {
  id                 String              @id
  userId             String
  /// Stripe customer id. Cached on every row of the same user; we look it
  /// up via the user's first row in `ensureCustomer`.
  providerCustomerId String
  /// Stripe payment method id (pm_xxx). Globally unique.
  providerMethodId   String              @unique
  brand              String
  last4              String
  expMonth           Int
  expYear            Int
  isDefault          Boolean             @default(false)
  status             PaymentMethodStatus @default(ACTIVE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, isDefault])
}

model MembershipBillingEvent {
  id              String                     @id
  membershipId    String
  /// Stripe event id (evt_xxx). Unique so webhook re-delivery is a no-op.
  providerEventId String                     @unique
  kind            MembershipBillingEventKind
  amountMinor     Int?
  currency        String?
  reason          String?
  /// Small JSON snapshot of the meaningful Stripe payload fields, kept for
  /// audit/debugging. Not the entire payload.
  rawSummary      Json?
  createdAt       DateTime                   @default(now())

  membership PlusMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId, createdAt])
  @@index([kind, createdAt])
}

